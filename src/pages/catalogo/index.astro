---
import LayoutTienda from "../../layouts/LayoutTienda.astro";
import { productos } from "../../data/productos.js";

// Convertimos los productos en un objeto agrupado por categoría usando JS puro
// Ejemplo: { "Ropa": [...], "Peluches": [...] }
const productosPorCategoria = productos.reduce((acc, producto) => {
  if (!acc[producto.categoria]) {
    acc[producto.categoria] = [];
  }
  acc[producto.categoria].push(producto);
  return acc;
}, {});

// Obtenemos una lista con los nombres de las categorías disponibles
const categorias = Object.keys(productosPorCategoria);
---

<LayoutTienda
  title="Catálogo por Categorías | Tejidos Mágicos"
  themeColor="#4ecdc4"
>
  <h2 class="titulo-pagina">🌸 Nuestro Catálogo de Artesanías 🌸</h2>

  {
    categorias.map((categoria) => (
      <section class="categoria-seccion">
        <h3 class="categoria-nombre">✨ {categoria}</h3>

        <div class="grid-productos">
          {productosPorCategoria[categoria].map((prod) => (
            <div class="tarjeta-producto">
              <img src={prod.imagen} alt={prod.nombre} class="producto-img" />
              <h4>{prod.nombre}</h4>
              <p class="precio">{prod.precio}</p>

              <a href={`/producto/${prod.id}`} class="btn-detalles">
                Ver Detalles
              </a>
            </div>
          ))}
        </div>
      </section>
    ))
  }
</LayoutTienda>

<style>
  .titulo-pagina {
    text-align: center;
    color: #333;
    margin-bottom: 2rem;
  }
  .categoria-seccion {
    margin-bottom: 3rem;
  }
  .categoria-nombre {
    font-size: 1.6rem;
    color: var(--theme-color);
    border-bottom: 2px solid #eee;
    padding-bottom: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .grid-productos {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.5rem;
  }
  .tarjeta-producto {
    background: white;
    border: 1px solid #eaeaea;
    border-radius: 12px;
    padding: 1rem;
    text-align: center;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.02);
    transition: transform 0.2s;
  }
  .tarjeta-producto:hover {
    transform: translateY(-5px);
  }
  .producto-img {
    width: 100%;
    height: 160px;
    object-fit: cover;
    border-radius: 8px;
    background-color: #f5f5f5;
  }
  .precio {
    font-weight: bold;
    color: #555;
    margin: 0.5rem 0 1rem 0;
  }
  .btn-detalles {
    display: block;
    background-color: var(--theme-color);
    color: white;
    text-decoration: none;
    padding: 10px;
    border-radius: 6px;
    font-weight: bold;
    font-size: 0.9rem;
  }
  .btn-detalles:hover {
    opacity: 0.9;
  }
</style>
